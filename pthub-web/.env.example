# Supabase 설정
# Vercel 배포 시: Project Settings → Environment Variables 에 등록
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ── 방문자 통계 (/admin) — 나만 보기 위한 설정 ──
# service_role 키: RLS 우회 권한. 절대 공개 금지. NEXT_PUBLIC_ 접두사 붙이지 말 것.
SUPABASE_SERVICE_KEY=eyJhbGc...
# 관리자 페이지 접근 토큰. 길고 무작위한 값으로. /admin 에서 이 토큰으로 로그인(쿠키).
ADMIN_TOKEN=change-me-to-a-long-random-string
# (선택) 방문자 해시 솔트. 미설정 시 기본값 사용.
TRACK_SALT=any-random-string

# ── 이메일 알림 (일정 제보 / 오류 신고 시 메일 발송) ──
# Resend(resend.com) API 키. 미설정 시 메일 발송만 스킵(DB 저장은 정상).
RESEND_API_KEY=re_xxxxxxxx
# (선택) 수신 이메일. 기본 ehdgus3278@gmail.com
MAIL_TO=ehdgus3278@gmail.com
# (선택) 발신 표기. 커스텀 도메인 인증 전에는 onboarding@resend.dev 만 가능.
MAIL_FROM=PT-Hub <onboarding@resend.dev>
